# ==========================
# Database
# ==========================
DATABASE_URL=postgresql+asyncpg://healthai:healthai_pass@localhost:5432/healthai_db

# ==========================
# JWT Authentication
# ==========================
JWT_SECRET_KEY=change-me-to-a-random-64-char-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================
# Google Gemini AI
# ==========================
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_EMBEDDING_MODEL=models/embedding-001
GEMINI_LLM_MODEL=gemini-2.5-flash

# ==========================
# MLflow
# ==========================
MLFLOW_TRACKING_URI=http://localhost:5000

# ==========================
# Application
# ==========================
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
APP_NAME=Health Intelligence System
APP_VERSION=0.1.0

# ==========================
# Vector Store
# ==========================
FAISS_INDEX_PATH=ml/models/faiss_index
